generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Vendor {
  id             Int        @id @default(autoincrement())
  name           String
  normalizedName String     @unique
  platforms      Platform[]
  commands       Command[]
  platformLinks  PlatformLink[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Platform {
  id             Int                @id @default(autoincrement())
  name           String
  normalizedName String             @unique
  vendorId       Int
  vendor         Vendor             @relation(fields: [vendorId], references: [id])
  hostTypeLinks  HostTypePlatform[]
  commands       Command[]
  links          PlatformLink[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Category {
  id              Int        @id @default(autoincrement())
  name            String
  normalizedName  String     @unique
  groupOrderIndex Int        @default(0)
  hostTypes       HostType[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model HostType {
  id              Int                @id @default(autoincrement())
  name            String
  normalizedName  String             @unique
  categoryId      Int
  groupOrderIndex Int                @default(0)
  category        Category           @relation(fields: [categoryId], references: [id])
  platforms       HostTypePlatform[]
  commands        Command[]
  links           PlatformLink[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model HostTypePlatform {
  hostTypeId Int
  platformId Int
  hostType   HostType @relation(fields: [hostTypeId], references: [id])
  platform   Platform @relation(fields: [platformId], references: [id])

  @@id([hostTypeId, platformId])
}

model Tag {
  id             Int          @id @default(autoincrement())
  name           String
  normalizedName String
  kind           TagKind      @default(COMMAND)
  commandTags    CommandTag[]
  platformLinkTags PlatformLinkTag[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([normalizedName, kind])
}

model Command {
  id           Int              @id @default(autoincrement())
  title        String
  description  String?
  commandText  String
  hostTypeId   Int
  platformId   Int?
  vendorId     Int?
  visibility   Visibility       @default(PUBLIC)
  ownerUserId  String?
  deviceBindingMode DeviceBindingMode @default(INCLUDE_IN_DEVICE)
  danger       Boolean          @default(false)
  orderIndex   Int              @default(0)
  createdBy    String
  updatedBy    String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?

  hostType  HostType         @relation(fields: [hostTypeId], references: [id])
  platform  Platform?        @relation(fields: [platformId], references: [id])
  vendor    Vendor?          @relation(fields: [vendorId], references: [id])
  variables CommandVariable[]
  tags      CommandTag[]

  @@index([hostTypeId, platformId, vendorId, orderIndex])
  @@index([visibility, ownerUserId])
}

model PlatformLink {
  id              Int        @id @default(autoincrement())
  title           String
  urlTemplate     String
  commentTemplate String?
  platformId      Int?
  vendorId        Int?
  hostTypeId      Int
  visibility      Visibility @default(PUBLIC)
  ownerUserId     String?
  deviceBindingMode DeviceBindingMode @default(INCLUDE_IN_DEVICE)
  orderIndex      Int        @default(0)
  createdBy       String
  updatedBy       String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  platform Platform? @relation(fields: [platformId], references: [id])
  vendor   Vendor?   @relation(fields: [vendorId], references: [id])
  hostType HostType @relation(fields: [hostTypeId], references: [id])
  tags     PlatformLinkTag[]

  @@index([platformId, vendorId, hostTypeId, orderIndex])
  @@index([visibility, ownerUserId])
}

model CommandVariable {
  id           Int      @id @default(autoincrement())
  commandId    Int
  name         String
  label        String
  required     Boolean  @default(false)
  defaultValue String?
  placeholder  String?
  regex        String?
  command      Command  @relation(fields: [commandId], references: [id], onDelete: Cascade)

  @@index([commandId])
}

model CommandTag {
  commandId Int
  tagId     Int
  command   Command @relation(fields: [commandId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([commandId, tagId])
}

model PlatformLinkTag {
  platformLinkId Int
  tagId          Int
  platformLink   PlatformLink @relation(fields: [platformLinkId], references: [id], onDelete: Cascade)
  tag            Tag          @relation(fields: [tagId], references: [id])

  @@id([platformLinkId, tagId])
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum DeviceBindingMode {
  INCLUDE_IN_DEVICE
  EXCLUDE_FROM_DEVICE
}

enum TagKind {
  COMMAND
  LINK
}
